# Required — the only paid API. Get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Optional — model. Haiku is cheapest/fastest and plenty for this audit.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional — GoHighLevel Inbound Webhook trigger URL (from a GHL workflow).
# Leave blank to just log leads server-side while testing.
GHL_WEBHOOK_URL=

# Public — your Calendly link, used on the CTA buttons.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/calibrestudio
